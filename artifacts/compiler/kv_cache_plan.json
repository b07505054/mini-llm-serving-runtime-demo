{
  "schema_version": "0.1",
  "artifact_type": "kv_cache_plan",
  "model": "tiny-gpt",
  "block_size_tokens": 16,
  "num_blocks": 1024,
  "max_context_tokens": 4096,
  "total_token_capacity": 16384,
  "kv_dtype": "fp16",
  "bytes_per_token": 36864,
  "bytes_per_block": 589824,
  "memory_mb_at_full_capacity": 576,
  "eviction_policy": "lru_finished_prefix",
  "admission_policy": "prefix_aware_capacity",
  "allocation_strategy": "block_based",
  "paged_attention_enabled": true,
  "block_table_enabled": true,
  "prefix_cache_enabled": true,
  "prefix_cache_policy": {
    "enabled": true,
    "hash_algorithm": "sha256",
    "model_version": "tiny-gpt-v0.1",
    "min_prefix_tokens": 64,
    "max_prefix_entries": 128,
    "evictable_state": "finished",
    "track_ref_count": true,
    "runtime_events": [
      "prefix_cache_hit",
      "prefix_cache_miss",
      "kv_blocks_evicted",
      "admission_rejected"
    ],
    "runtime_metrics": [
      "prefix_cache_hit_rate",
      "kv_blocks_reused",
      "kv_blocks_evicted",
      "admission_rejection_rate",
      "prefill_latency_saved_ms"
    ]
  },
  "sliding_window_enabled": false
}
